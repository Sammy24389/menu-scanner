# PHP Menu Scanner System - Git Ignore

# Dependencies
/vendor/
/composer.lock

# Node.js / Next.js (not used)
/node_modules/
.next/
/out/
/build/
*.log

# Environment files
.env
.env.local
.env.production

# Uploaded files
/uploads/*
!/uploads/.gitkeep

# Generated QR codes
/public/qr/*

# SQLite database (generated)
/data/*
!/data/.gitkeep

# IDE and Editor files
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# Cache
/cache/
*.cache

# Temporary files
tmp/
temp/
*.tmp

# TypeScript build artifacts
src/components/ui/
src/lib/supabase/
src/middleware.ts
src/types/
src/app/\(admin\)/
src/app/\(auth\)/
src/app/\(public\)/
src/components/admin/
src/components/menu/
next-env.d.ts
