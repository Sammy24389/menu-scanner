# PHP Menu Scanner System - Git Ignore

# PHP Dependencies
/vendor/
/composer.lock

# Environment files
.env
.env.local
.env.*

# Uploaded files (keep directory, ignore contents)
/uploads/*
!/uploads/.gitkeep

# Generated QR codes
/public/qr/*

# SQLite database (generated at runtime)
/data/*
!/data/.gitkeep

# IDE and Editor
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# Logs
*.log

# Cache
/cache/
*.cache

# Temporary
tmp/
temp/
*.tmp

# Deployment configs (keep for reference)
render.yaml
railway.json
Dockerfile
